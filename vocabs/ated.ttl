ated:ability
    a skos:Concept ;
    skos:inScheme ated: ;
    skos:topConceptOf ated: ;
    skos:prefLabel "Ability"@en ;
    skos:scopeNote "The degree of actual power present in an organism or system to perform a given physical or mental act (Note: use a more specific term if possible)"@en ;
    skos:narrower ated:academicAbility, ated:cognitiveAbility, ated:competence, ated:expertise, ated:languageProficiency, ated:leadership, ated:nonverbalAbility, ated:skills, ated:spatialAbility, ated:talent, ated:verbalAbility ;
    skos:related ated:abilityGrouping, ated:abilityIdentification, ated:achievement, ated:aptitude, ated:aspiration, ated:difficultyLevel, ated:disabilities, ated:gifted, ated:mixedAbilityGrouping, ated:performance, ated:productivity, ated:qualifications, ated:raschModel, ated:readiness, ated:testWiseness ;
    dcterms:subject atedsc:120 ;
    dcterms:modified "1984-01"^^xsd:gYearMonth .

ated:abilityGrouping
    a skos:Concept ;
    skos:inScheme ated: ;
    skos:prefLabel "Ability grouping"@en ;
    skos:altLabel "Streaming"@en ;
    skos:scopeNote "Selection or classification of students for schools, classes, or other educational programs based on differences in ability or achievement"@en ;
    skos:broader ated:groupingTeachingPurposes ;
    skos:related ated:ability, ated:abilityIdentification, ated:academicAbility, ated:academicAchievement, ated:advancedPlacement, ated:flexibleProgression, ated:homogeneousGrouping, ated:nongradedTeachingGrouping, ated:schoolYearLevels ;
