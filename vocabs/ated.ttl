ated:abilityIdentification
    a skos:Concept ;
    skos:inScheme ated: ;
    skos:prefLabel "Ability identification"@en ;
    skos:scopeNote "Identification of an individual's actual power to perform various acts (Note: do not confuse with \"Talent identification,\" which frequently refers to innate aptitudes or abilities, especially of the gifted)"@en ;
    skos:broader ated:identification ;
    skos:related ated:ability, ated:abilityGrouping, ated:aptitudeTests, ated:certification, ated:criticalIncidentsMethod, ated:disabilityIdentification, ated:earlyIdentification, ated:factorAnalysis, ated:intelligenceTests, ated:mixedAbilityGrouping, ated:probationaryPeriods, ated:skillAnalysis, ated:talentIdentification ;
